		JLabel status = new JLabel("Ready");
		status.setBorder(BorderFactory.createEmptyBorder(6, 10, 6, 10));
		p.add(status, BorderLayout.WEST);
		return p;
	}

	private void loadCsvPreview(File f)
	{
		csvModel.setRowCount(0);
		csvModel.setColumnCount(0);

		try (BufferedReader br = Files.newBufferedReader(f.toPath(), StandardCharsets.UTF_8))
			{
			String header = br.readLine();
			if (header == null)
				{
				append("[ERROR] Empty file.\n");
				return;
				}

			String[] headers = header.split(",", -1);
			for (String h : headers)
				{
				csvModel.addColumn(h.trim());
				}

			for (int i = 0; i < 50; i++)
				{
				String line = br.readLine();
				if (line == null)
					{
					break;
					}

				String[] parts = line.split(",", -1);
				if (parts.length < headers.length)
					{
					parts = Arrays.copyOf(parts, headers.length);
					}
				csvModel.addRow(parts);
				}

			append("[INFO] Preview loaded: " + f.getName() + "\n");
			} catch (Exception ex)
			{
			append("[ERROR] Failed to preview CSV: " + ex.getMessage() + "\n");
			}
	}

	private void populateNodes(int n)
	{
		nodesModel.setRowCount(0);
		for (int i = 1; i <= n; i++)
			{
			nodesModel.addRow(new Object[]
				{
				"Client-" + i, "READY"
				});
			}
		append("[INFO] Nodes displayed: " + n + "\n");
	}

	private int clampUiNodes(int requested)
	{
		if (requested > MAX_UI_NODES)
			{
			append("[WARN] Requested " + requested + " nodes. UI capped to " + MAX_UI_NODES + ".\n");
			return MAX_UI_NODES;
			}
		return Math.max(1, requested);
	}

	private void append(String s)
