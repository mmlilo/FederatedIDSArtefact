	private void loadCsvPreview(File file)
	{
		csvModel.setRowCount(0);
		csvModel.setColumnCount(0);
		labelColumnCombo.removeAllItems();
		labelPreviewArea.setText("");
		partitionPreviewArea.setText("");
		fullPartitionArea.setText("");
		previewRowsLabel.setText("Preview rows: 0");
		totalColumnsLabel.setText("Columns: 0");
		selectedLabelColumnLabel.setText("Label column: none");
		previewedRowCount = 0;

		fullDatasetRows.clear();
		fullDatasetHeaders = new String[0];
		generatedPartitions.clear();

		try (BufferedReader br = Files.newBufferedReader(file.toPath(), StandardCharsets.UTF_8))
			{
			String headerLine = br.readLine();

			if (headerLine == null)
				{
				append("[ERROR] Selected file is empty.\n");
				return;
				}

			String[] headers = headerLine.split(",", -1);
			fullDatasetHeaders = headers;

			for (String header : headers)
				{
				String cleanHeader = header.trim();
				csvModel.addColumn(cleanHeader);
				labelColumnCombo.addItem(cleanHeader);
				}

			int previewCount = 0;
			String line;

			while ((line = br.readLine()) != null)
				{
				String[] parts = line.split(",", -1);

				if (parts.length < headers.length)
					{
					parts = Arrays.copyOf(parts, headers.length);
					}

				fullDatasetRows.add(parts);

				if (previewCount < 50)
					{
					csvModel.addRow(parts);
					previewCount++;
					}
				}

			previewedRowCount = previewCount;
			previewRowsLabel.setText("Preview rows: " + previewCount);
			totalColumnsLabel.setText("Columns: " + headers.length);

			if (labelColumnCombo.getItemCount() > 0)
				{
				labelColumnCombo.setSelectedIndex(headers.length - 1);
				}

			append("[INFO] CSV preview loaded: " + file.getName() + "\n");
			append("[INFO] Full dataset rows loaded into memory: " + fullDatasetRows.size() + "\n");

			updatePartitionPreview();
			} catch (Exception ex)
			{
			append("[ERROR] Failed to load CSV preview: " + ex.getMessage() + "\n");
			}
	}

