	private void generateIIDPartitions(int clientCount, List<String[]> benignRows,
		List<String[]> attackRows, List<String[]> otherRows)
	{
		List<String[]> allRows = new ArrayList<>();
		allRows.addAll(benignRows);
		allRows.addAll(attackRows);
		allRows.addAll(otherRows);

		Collections.shuffle(allRows, new Random());

		for (int i = 1; i <= clientCount; i++)
			{
			generatedPartitions.put("Client-" + i, new ArrayList<>());
			}

		for (int i = 0; i < allRows.size(); i++)
			{
			String clientId = "Client-" + ((i % clientCount) + 1);
			generatedPartitions.get(clientId).add(allRows.get(i));
			}
	}

	private int findHeaderIndex(String columnName)
	{
		for (int i = 0; i < fullDatasetHeaders.length; i++)
			{
			if (fullDatasetHeaders[i].trim().equals(columnName))
				{
				return i;
				}
			}
		return -1;
	}

	private void generateNonIIDPartitions(int clientCount, List<String[]> benignRows,
		List<String[]> attackRows, List<String[]> otherRows)
	{
		for (int i = 1; i <= clientCount; i++)
			{
			generatedPartitions.put("Client-" + i, new ArrayList<>());
			}

		int half = Math.max(1, clientCount / 2);

		int benignIndex = 0;
		int attackIndex = 0;
		int otherIndex = 0;

		for (int i = 1; i <= half; i++)
			{
			String clientId = "Client-" + i;
			List<String[]> partition = generatedPartitions.get(clientId);

			int share = Math.max(1, benignRows.size() / half);
			for (int j = 0; j < share && benignIndex < benignRows.size(); j++)
				{
				partition.add(benignRows.get(benignIndex++));
				}
			}

		for (int i = half + 1; i <= clientCount; i++)
			{
			String clientId = "Client-" + i;
			List<String[]> partition = generatedPartitions.get(clientId);

			int denom = Math.max(1, clientCount - half);
			int share = Math.max(1, attackRows.size() / denom);
			for (int j = 0; j < share && attackIndex < attackRows.size(); j++)
				{
				partition.add(attackRows.get(attackIndex++));
				}
			}

		int clientPointer = 1;
		while (benignIndex < benignRows.size())
			{
			generatedPartitions.get("Client-" + clientPointer).add(benignRows.get(benignIndex++));
			clientPointer = (clientPointer % clientCount) + 1;
			}

		while (attackIndex < attackRows.size())
			{
			generatedPartitions.get("Client-" + clientPointer).add(attackRows.get(attackIndex++));
			clientPointer = (clientPointer % clientCount) + 1;
			}

		while (otherIndex < otherRows.size())
			{
			generatedPartitions.get("Client-" + clientPointer).add(otherRows.get(otherIndex++));
			clientPointer = (clientPointer % clientCount) + 1;
			}
	}

	private void renderFullPartitionSummary(String partitionType, int benignCount,
		int attackCount, int otherCount)
	{
		StringBuilder sb = new StringBuilder();

		sb.append("Full dataset partition generation\n");
		sb.append("========================================\n");
		sb.append("Partition type: ").append(partitionType).append("\n");
		sb.append("Total loaded rows: ").append(fullDatasetRows.size()).append("\n");
		sb.append("Benign rows: ").append(benignCount).append("\n");
		sb.append("Attack rows: ").append(attackCount).append("\n");
		sb.append("Other rows: ").append(otherCount).append("\n");
		sb.append("Clients generated: ").append(generatedPartitions.size()).append("\n\n");

		sb.append("Client partition sizes\n");
		sb.append("----------------------------------------\n");

		for (Map.Entry<String, List<String[]>> entry : generatedPartitions.entrySet())
			{
			sb.append(entry.getKey())
				.append(": ")
				.append(entry.getValue().size())
				.append(" rows\n");
			}

		fullPartitionArea.setText(sb.toString());
		fullPartitionArea.setCaretPosition(0);
	}

	private void generateFullDatasetPartitions()
	{
		generatedPartitions.clear();
		fullPartitionArea.setText("");

		if (selectedDatasetFile == null)
			{
			fullPartitionArea.setText("No dataset selected.");
			return;
			}

		if (fullDatasetRows.isEmpty())
			{
			fullPartitionArea.setText("Dataset rows are not loaded.");
			return;
			}

		Object selected = labelColumnCombo.getSelectedItem();
		if (selected == null)
			{
			fullPartitionArea.setText("No label column selected.");
			return;
			}

		String labelColumn = selected.toString();
		int labelColIndex = findHeaderIndex(labelColumn);

		if (labelColIndex < 0)
			{
			fullPartitionArea.setText("Could not find selected label column.");
			return;
			}

		String benignValue = benignValueField.getText().trim();
		String attackValue = attackValueField.getText().trim();
		String partitionType = partitionTypeCombo.getSelectedItem().toString();
		int clientCount = (Integer) clientPreviewSpinner.getValue();

		List<String[]> benignRows = new ArrayList<>();
		List<String[]> attackRows = new ArrayList<>();
		List<String[]> otherRows = new ArrayList<>();

		for (String[] row : fullDatasetRows)
			{
			String value = "";
			if (labelColIndex < row.length && row[labelColIndex] != null)
				{
				value = row[labelColIndex].trim();
				}

			if (value.equalsIgnoreCase(benignValue))
				{
				benignRows.add(row);
				} else if (value.equalsIgnoreCase(attackValue))
				{
				attackRows.add(row);
				} else
				{
				otherRows.add(row);
				}
			}

		if ("IID".equalsIgnoreCase(partitionType))
			{
			generateIIDPartitions(clientCount, benignRows, attackRows, otherRows);
			} else
			{
			generateNonIIDPartitions(clientCount, benignRows, attackRows, otherRows);
			}

		renderFullPartitionSummary(partitionType, benignRows.size(), attackRows.size(), otherRows.size());
		append("[INFO] Full dataset partitions generated: " + generatedPartitions.size() + " clients\n");
	}

