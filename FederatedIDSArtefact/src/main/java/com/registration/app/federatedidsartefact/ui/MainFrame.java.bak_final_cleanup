		{
			this.label = label;
			this.pct = pct;
		}
	}

	private static final class SummaryEvent implements UiEvent
	{

		final int training;
		final int done;
		final int errors;

		SummaryEvent(int training, int done, int errors)
		{
			this.training = training;
			this.done = done;
			this.errors = errors;
		}
	}

	private final class TrainingWorker extends SwingWorker<Void, UiEvent>
	{

		private final int clients;
		private final int rounds;
		private final Random rnd = new Random();

		TrainingWorker(int clients, int rounds)
		{
			this.clients = clients;
			this.rounds = rounds;
		}

		@Override
		protected Void doInBackground() throws Exception
		{
			for (int i = 0; i < visibleClients; i++)
				{
				publish(new StatusEvent(i, READY));
				}

			double sampleFraction = clients > 500 ? 0.05 : 0.25;

			for (int r = 1; r <= rounds; r++)
				{
				if (isCancelled())
					{
					break;
					}

				publish(new LogEvent("[ROUND " + r + "] selecting clients...\n"));

				int k = Math.max(1, (int) Math.round(clients * sampleFraction));
				List<Integer> idxs = new ArrayList<>(clients);
				for (int i = 0; i < clients; i++)
					{
					idxs.add(i);
					}

				Collections.shuffle(idxs, rnd);
				List<Integer> selected = idxs.subList(0, k);

				int currentTraining = selected.size();
				int currentDone = 0;
				int currentErrors = 0;

				for (int idx : selected)
					{
					if (idx < visibleClients)
						{
						publish(new StatusEvent(idx, TRAINING));
						}
					}

				publish(new SummaryEvent(currentTraining, currentDone, currentErrors));
				publish(new LogEvent("[ROUND " + r + "] local training (" + k + " clients)...\n"));

				Thread.sleep(250 + rnd.nextInt(250));

				for (int idx : selected)
					{
					boolean fail = rnd.nextDouble() < 0.02;

					if (fail)
						{
						currentErrors++;
						if (idx < visibleClients)
							{
							publish(new StatusEvent(idx, ERROR));
							}
						} else
						{
						currentDone++;
						if (idx < visibleClients)
							{
							publish(new StatusEvent(idx, DONE));
							}
						}
					}

				currentTraining = 0;
				publish(new SummaryEvent(currentTraining, currentDone, currentErrors));
				publish(new LogEvent("[ROUND " + r + "] aggregation complete. errors=" + currentErrors + "\n"));

				int pct = (int) Math.round((r * 100.0) / rounds);
				publish(new ProgressEvent("Round " + r + "/" + rounds, pct));

				Thread.sleep(200);

				for (int idx : selected)
					{
					if (idx < visibleClients)
						{
						publish(new StatusEvent(idx, READY));
						}
					}

				publish(new SummaryEvent(0, 0, currentErrors));
				}

			return null;
		}

		@Override
		protected void process(List<UiEvent> chunks)
		{
			for (UiEvent e : chunks)
				{
				if (e instanceof LogEvent le)
					{
					append(le.msg);
					} else if (e instanceof StatusEvent se)
					{
					setNodeStatus(se.row, se.st);
					} else if (e instanceof ProgressEvent pe)
					{
					progress.setValue(pe.pct);
					progress.setString(pe.label);
					} else if (e instanceof SummaryEvent sm)
					{
					trainingCount = sm.training;
					doneCount = sm.done;
					errorCount = sm.errors;
					refreshSummaryLabels();
					}
				}
		}

		@Override
		protected void done()
		{
			startBtn.setEnabled(true);
			stopBtn.setEnabled(false);

			if (isCancelled())
				{
				progress.setValue(0);
				progress.setString("Cancelled");
				append("[INFO] Simulation cancelled.\n");
				} else
				{
				progress.setValue(100);
				progress.setString("Done");
				append("[INFO] Simulation complete.\n");
				}
		}
	}

	private static class StatusRenderer extends DefaultTableCellRenderer
	{

		@Override
		public Component getTableCellRendererComponent(JTable table, Object value,
			boolean isSelected, boolean hasFocus,
			int row, int column)
		{
			Component c = super.getTableCellRendererComponent(table, value, isSelected, hasFocus, row, column);

			if (!isSelected)
				{
				String s = String.valueOf(value);
				switch (s)
					{
					case "READY" ->
						c.setBackground(new Color(220, 240, 255));
					case "TRAINING" ->
						c.setBackground(new Color(255, 245, 200));
					case "DONE" ->
						c.setBackground(new Color(215, 255, 215));
					case "ERROR" ->
						c.setBackground(new Color(255, 215, 215));
					default ->
						c.setBackground(Color.WHITE);
					}
				}

			return c;
		}
	}

	private void updatePartitionPreview()
	{
		Object selected = labelColumnCombo.getSelectedItem();

		if (selected == null || csvModel.getRowCount() == 0)
			{
			partitionPreviewArea.setText("No dataset loaded yet.");
			return;
			}

		String labelColumn = selected.toString();
		int labelColIndex = csvModel.findColumn(labelColumn);

		if (labelColIndex < 0)
			{
			partitionPreviewArea.setText("Could not find label column.");
			return;
			}

		String benignValue = benignValueField.getText().trim();
		String attackValue = attackValueField.getText().trim();
		String partitionType = partitionTypeCombo.getSelectedItem().toString();
		int clientCount = (Integer) clientPreviewSpinner.getValue();

		int benignCount = 0;
		int attackCount = 0;
		int otherCount = 0;

		for (int i = 0; i < csvModel.getRowCount(); i++)
			{
			Object valueObj = csvModel.getValueAt(i, labelColIndex);
			String value = valueObj == null ? "" : valueObj.toString().trim();

			if (value.equalsIgnoreCase(benignValue))
				{
				benignCount++;
				} else if (value.equalsIgnoreCase(attackValue))
				{
				attackCount++;
				} else
				{
				otherCount++;
				}
			}

		StringBuilder sb = new StringBuilder();
		sb.append("Partition preview\n");
		sb.append("==============================\n");
		sb.append("Partition type: ").append(partitionType).append("\n");
		sb.append("Preview rows loaded: ").append(previewedRowCount).append("\n");
		sb.append("Client preview count: ").append(clientCount).append("\n");
		sb.append("Label column: ").append(labelColumn).append("\n");
		sb.append("Benign value: ").append(benignValue).append("\n");
		sb.append("Attack value: ").append(attackValue).append("\n\n");

		sb.append("Class counts in preview\n");
		sb.append("------------------------------\n");
		sb.append("Benign rows: ").append(benignCount).append("\n");
		sb.append("Attack rows: ").append(attackCount).append("\n");
		sb.append("Other rows: ").append(otherCount).append("\n\n");

		sb.append("Rows per client preview\n");
}
