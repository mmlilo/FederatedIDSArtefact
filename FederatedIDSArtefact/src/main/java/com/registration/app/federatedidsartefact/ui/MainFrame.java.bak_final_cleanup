	private int getPartitionSize(String clientId)
	{
		List<String[]> rows = generatedPartitions.get(clientId);
		return rows == null ? 0 : rows.size();
	}

	private String describePartitionType(String clientId)
	{
		List<String[]> rows = generatedPartitions.get(clientId);

		if (rows == null || rows.isEmpty())
			{
			return "no data";
			}

		Object selected = labelColumnCombo.getSelectedItem();
		if (selected == null)
			{
			return "unknown";
			}

		int labelColIndex = findHeaderIndex(selected.toString());
		if (labelColIndex < 0)
			{
			return "unknown";
			}

		String benignValue = benignValueField.getText().trim();
		String attackValue = attackValueField.getText().trim();

		int benign = 0;
		int attack = 0;
		int other = 0;

		for (String[] row : rows)
			{
			String value = "";
			if (labelColIndex < row.length && row[labelColIndex] != null)
				{
				value = row[labelColIndex].trim();
				}

			if (value.equalsIgnoreCase(benignValue))
				{
				benign++;
				} else if (value.equalsIgnoreCase(attackValue))
				{
				attack++;
				} else
				{
				other++;
				}
			}

		if (benign > attack && benign > other)
			{
			return "mostly benign";
			} else if (attack > benign && attack > other)
			{
			return "mostly attack";
			} else
			{
			return "mixed";
			}
	}

	private boolean hasGeneratedPartitions()
	{
		return generatedPartitions != null && !generatedPartitions.isEmpty();
	}

