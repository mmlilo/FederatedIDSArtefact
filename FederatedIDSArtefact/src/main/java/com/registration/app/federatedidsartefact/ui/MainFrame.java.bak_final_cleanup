	private void initialiseNodeView(int requestedClients)
	{
		totalSimulatedClients = Math.max(1, requestedClients);
		visibleClients = Math.min(totalSimulatedClients, MAX_VISIBLE_UI_NODES);

		nodesModel.setRowCount(0);
		for (int i = 1; i <= visibleClients; i++)
			{
			nodesModel.addRow(new Object[]
				{
				"Client-" + i, READY
				});
			}

		trainingCount = 0;
		doneCount = 0;
		errorCount = 0;

		refreshSummaryLabels();
	}

	private void refreshSummaryLabels()
	{
		totalClientsLabel.setText("Total clients: " + totalSimulatedClients);
		visibleClientsLabel.setText("Visible clients: " + visibleClients);
		trainingCountLabel.setText("Training: " + trainingCount);
		doneCountLabel.setText("Done: " + doneCount);
		errorCountLabel.setText("Errors: " + errorCount);
	}

	private void startSimulation()
	{
		if (worker != null && !worker.isDone())
			{
			append("[WARN] Already running.\n");
			return;
			}

		int requestedClients = parseIntSafe(clientsField.getText(), 30);
		int rounds = Math.max(1, parseIntSafe(roundsField.getText(), 15));

		initialiseNodeView(requestedClients);

		append("[INFO] Starting simulation...\n");
		append("[INFO] Total simulated clients: " + totalSimulatedClients + "\n");
		append("[INFO] Visible dashboard clients: " + visibleClients + "\n");
		append("[INFO] Rounds: " + rounds + "\n");

		if (totalSimulatedClients > visibleClients)
			{
			append("[INFO] Dashboard capped to first " + visibleClients + " clients for responsiveness.\n");
			}

		startBtn.setEnabled(false);
		stopBtn.setEnabled(true);
		progress.setValue(0);
		progress.setString("Running...");

		worker = new TrainingWorker(totalSimulatedClients, rounds);
		worker.execute();
	}

	private void stopSimulation()
	{
		if (worker != null && !worker.isDone())
			{
			worker.cancel(true);
			append("[INFO] Stop requested.\n");
			}
	}

